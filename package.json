{
  "name": "pulselane",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api start:dev",
    "build:web": "pnpm --dir apps/web build",
    "build:api": "pnpm --dir apps/api build",
    "lint:web": "pnpm --dir apps/web lint",
    "lint:api": "pnpm --dir apps/api lint",
    "test:api": "pnpm --dir apps/api test",
    "test:api:integration": "pnpm --dir apps/api test:integration",
    "db:seed": "pnpm --dir apps/api db:seed",
    "db:migrate": "pnpm --dir apps/api prisma migrate deploy",
    "setup:dev": "pnpm install && docker compose up -d"
  }
}
