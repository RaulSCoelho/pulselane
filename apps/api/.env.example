# --------------------------------------
# app
# --------------------------------------
PORT=3001
NODE_ENV=development
ALLOWED_CORS_ORIGINS=http://localhost:3000
# Set true when the API sits behind the Next.js server/proxy and receives x-forwarded-* headers.
# You can also use a hop count like 1 or trusted proxy CIDRs such as 127.0.0.1,10.0.0.0/8.
TRUST_PROXY=true

# --------------------------------------
# database
# --------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulselane?schema=public

# --------------------------------------
# observability
# --------------------------------------
LOG_LEVEL=debug
SLOW_REQUEST_THRESHOLD_MS=1000
METRICS_BEARER_TOKEN=change-this-metrics-bearer-token-with-at-least-32-characters
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# --------------------------------------
# throttling
# --------------------------------------
THROTTLING_ENABLED=true
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120

# --------------------------------------
# cookies
# --------------------------------------
# production:
# - set COOKIE_SECURE=true
# - prefer COOKIE_SAME_SITE=none only for cross-site HTTPS deployments
COOKIE_SECRET=change-this-cookie-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/api/v1/auth

# --------------------------------------
# auth
# --------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# --------------------------------------
# web
# --------------------------------------
APP_WEB_URL=http://localhost:3000

# --------------------------------------
# email
# --------------------------------------
# local default uses logger transport
# production SMTP requires host/user/password
EMAIL_FROM_NAME=Pulselane
EMAIL_FROM_ADDRESS=no-reply@pulselane.com
EMAIL_TRANSPORT=logger
EMAIL_QUEUE_DRAIN_DELAY_MS=30000
EMAIL_QUEUE_STALLED_INTERVAL_MS=120000
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# --------------------------------------
# stripe
# --------------------------------------
# when STRIPE_ENABLED=true, all Stripe values below are required
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=

# --------------------------------------
# redis
# --------------------------------------
# local default keeps Redis enabled because docker-compose provides it
# production can set REDIS_REQUIRED=false only if Redis is treated as optional
REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_URL=redis://localhost:6379
