# --------------------------------------
# app
# --------------------------------------
PORT=3001
NODE_ENV=development
ALLOWED_CORS_ORIGINS=http://localhost:3000

# --------------------------------------
# database
# --------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulselane?schema=public

# --------------------------------------
# cookies
# --------------------------------------
COOKIE_SECRET=change-this-cookie-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# --------------------------------------
# auth
# --------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# --------------------------------------
# web
# --------------------------------------
APP_WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --------------------------------------
# email
# --------------------------------------
EMAIL_FROM_NAME=Pulselane
EMAIL_FROM_ADDRESS=no-reply@pulselane.local
EMAIL_TRANSPORT=logger
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# --------------------------------------
# stripe
# --------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=

# --------------------------------------
# redis
# --------------------------------------
REDIS_ENABLED=false
REDIS_REQUIRED=false
REDIS_URL=redis://localhost:6379