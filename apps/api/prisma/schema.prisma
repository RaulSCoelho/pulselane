generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles are enforced in organization-scoped guards and determine which
// controllers can mutate tenant data.
enum MembershipRole {
  owner
  admin
  member
  viewer
}

enum ClientStatus {
  active
  inactive
  archived
}

enum ProjectStatus {
  active
  on_hold
  completed
  archived
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
  archived
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum AuditLogAction {
  created
  updated
  archived
  deleted
}

enum OrganizationInvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum EmailDeliveryStatus {
  pending
  sent
  failed
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique @db.Citext
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  authSessions            AuthSession[]
  memberships             Membership[]
  tasks                   Task[]
  auditLogs               AuditLog[]
  organizationInvitations OrganizationInvitation[] @relation("OrganizationInvitationInvitedByUser")
  emailDeliveries         EmailDelivery[]          @relation("EmailDeliverySentByUser")

  @@map("users")
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  deviceId         String    @map("device_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  lastUsedAt       DateTime? @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")
  compromisedAt    DateTime? @map("compromised_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique @db.Citext
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships             Membership[]
  clients                 Client[]
  projects                Project[]
  tasks                   Task[]
  auditLogs               AuditLog[]
  organizationInvitations OrganizationInvitation[]
  emailDeliveries         EmailDelivery[]

  @@map("organizations")
}

model Membership {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  organizationId String         @map("organization_id")
  role           MembershipRole
  createdAt      DateTime       @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model Client {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  email          String?      @db.Citext
  companyName    String?      @map("company_name")
  status         ClientStatus @default(active)
  archivedAt     DateTime?    @map("archived_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([organizationId, createdAt])
  @@map("clients")
}

model Project {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  clientId       String        @map("client_id")
  name           String
  description    String?
  status         ProjectStatus @default(active)
  archivedAt     DateTime?     @map("archived_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([organizationId, createdAt])
  @@map("projects")
}

model Task {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  assigneeUserId String?      @map("assignee_user_id")
  title          String
  description    String?
  status         TaskStatus   @default(todo)
  priority       TaskPriority @default(medium)
  dueDate        DateTime?    @map("due_date")
  archivedAt     DateTime?    @map("archived_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?        @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([assigneeUserId])
  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([organizationId, archivedAt])
  @@index([organizationId, createdAt])
  @@map("tasks")
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  actorUserId    String         @map("actor_user_id")
  entityType     String         @map("entity_type")
  entityId       String         @map("entity_id")
  action         AuditLogAction
  metadata       Json?          @map("metadata")
  createdAt      DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User         @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

model OrganizationInvitation {
  id              String                       @id @default(cuid())
  organizationId  String                       @map("organization_id")
  invitedByUserId String                       @map("invited_by_user_id")
  email           String                       @db.Citext
  role            MembershipRole
  token           String                       @unique
  status          OrganizationInvitationStatus @default(pending)
  expiresAt       DateTime                     @map("expires_at")
  acceptedAt      DateTime?                    @map("accepted_at")
  revokedAt       DateTime?                    @map("revoked_at")
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("OrganizationInvitationInvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([organizationId, status])
  @@index([organizationId, email])
  @@map("organization_invitations")
}

model EmailDelivery {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  sentBy         String?             @map("sent_by")
  to             String              @db.Citext
  subject        String
  transport      String
  status         EmailDeliveryStatus @default(pending)
  error          String?
  metadata       Json?               @map("metadata")
  sentAt         DateTime?           @map("sent_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("EmailDeliverySentByUser", fields: [sentBy], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([sentBy])
  @@index([to])
  @@map("email_deliveries")
}
